<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwExceptions="false"
      internalLogLevel="Warn"
      internalLogFile="internal-nlog.txt">

  <targets>
    <!-- 文件日志目标 -->
    <!-- 使用 ${cached} 缓存日期值，确保整个进程使用同一个日志文件 -->
    <target name="fileTarget"
            xsi:type="File"
            fileName="${basedir}/logs/eyesharp-${cached:${date:format=yyyyMMdd}:cached=true}.log"
            layout="${longdate} ${level:uppercase=true:padding=-5} ${logger:shortName=true} ${message} ${exception:format=ToString,Data}"
            archiveFileName="${basedir}/logs/archive/eyesharp-{#}.log"
            archiveNumbering="Date"
            archiveDateFormat="yyyy-MM-dd"
            archiveEvery="Day"
            maxArchiveFiles="30"
            encoding="utf-8"
            keepFileOpen="true"
            concurrentWrites="true" />

    <!-- 调试输出目标（开发时使用） -->
    <target name="debugTarget"
            xsi:type="Debugger"
            layout="${time} ${level:uppercase=true} ${message}" />
  </targets>

  <rules>
    <logger name="*" minlevel="Info" writeTo="fileTarget" />
    <logger name="*" minlevel="Debug" writeTo="debugTarget" />
  </rules>
</nlog>
