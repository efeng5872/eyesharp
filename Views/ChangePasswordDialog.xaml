<Window x:Class="eyesharp.Views.ChangePasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="修改密码 - EyeSharp"
        Width="500"
        Height="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Border Margin="30"
            Background="{StaticResource CardBackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题 -->
            <TextBlock Grid.Row="0"
                       Text="修改密码"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{StaticResource PrimaryBrush}"
                       Margin="0,0,0,20"/>

            <!-- 输入区域 -->
            <StackPanel Grid.Row="1">
                <!-- 旧密码 -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="旧密码："
                               FontSize="14"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}"/>

                    <PasswordBox Grid.Column="1"
                                 x:Name="OldPasswordBox"
                                 FontSize="14"
                                 Padding="8,6"
                                 PasswordChanged="OnOldPasswordChanged"
                                 BorderBrush="#E0E0E0"
                                 BorderThickness="1"
                                 Background="White"/>

                    <!-- 密码强度（仅对新密码显示） -->
                    <TextBlock Grid.Column="2"
                               x:Name="OldPasswordStrength"
                               FontSize="12"
                               FontWeight="Medium"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"
                               Foreground="#999999"/>
                </Grid>

                <!-- 新密码 -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="新密码："
                               FontSize="14"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}"/>

                    <PasswordBox Grid.Column="1"
                                 x:Name="NewPasswordBox"
                                 FontSize="14"
                                 Padding="8,6"
                                 PasswordChanged="OnNewPasswordChanged"
                                 BorderBrush="#E0E0E0"
                                 BorderThickness="1"
                                 Background="White"/>

                    <!-- 密码强度指示器 -->
                    <TextBlock Grid.Column="2"
                               x:Name="PasswordStrengthText"
                               Text="强度"
                               FontSize="12"
                               FontWeight="Medium"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"
                               Foreground="#999999"/>
                </Grid>

                <!-- 确认新密码 -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="确认新密码："
                               FontSize="14"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}"/>

                    <PasswordBox Grid.Column="1"
                                 x:Name="ConfirmPasswordBox"
                                 FontSize="14"
                                 Padding="8,6"
                                 PasswordChanged="OnConfirmPasswordChanged"
                                 BorderBrush="#E0E0E0"
                                 BorderThickness="1"
                                 Background="White"/>
                </Grid>

                <!-- 错误提示 -->
                <TextBlock x:Name="ErrorMessage"
                           FontSize="12"
                           Foreground="{StaticResource ErrorBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"
                           Visibility="Collapsed"/>

                <!-- 密码要求说明 -->
                <Border Background="#F5F5F5"
                        Padding="10"
                        CornerRadius="4"
                        Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="密码要求："
                                   FontSize="12"
                                   FontWeight="Medium"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,5"/>
                        <TextBlock Text="• 长度必须在 4-20 个字符之间"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="• 新密码不能与旧密码相同"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- 按钮 -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1"
                        Content="确定"
                        Click="OnOkClick"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="80"
                        Height="36"
                        Margin="0,0,10,0"
                        x:Name="OkButton"
                        IsEnabled="False"/>

                <Button Grid.Column="2"
                        Content="取消"
                        Click="OnCancelClick"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="80"
                        Height="36"/>
            </Grid>
        </Grid>
    </Border>
</Window>
