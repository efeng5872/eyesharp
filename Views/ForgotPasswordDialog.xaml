<Window x:Class="eyesharp.Views.ForgotPasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="重置确认 - EyeSharp"
        Width="500"
        Height="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Border Margin="30"
            Background="{StaticResource CardBackgroundBrush}"
            BorderBrush="{StaticResource WarningBrush}"
            BorderThickness="2"
            CornerRadius="8">
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 警告图标和标题 -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="⚠"
                           FontSize="36"
                           Foreground="{StaticResource WarningBrush}"
                           Margin="0,0,15,0"
                           VerticalAlignment="Top"/>

                <TextBlock Grid.Column="1"
                           Text="确认重置"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{StaticResource WarningBrush}"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- 说明文字 -->
            <StackPanel Grid.Row="1">
                <TextBlock Text="确定要重置所有配置吗？"
                           FontSize="16"
                           FontWeight="Medium"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="0,0,0,15"/>

                <TextBlock Text="此操作将清空所有设置："
                           FontSize="14"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="0,0,0,5"/>

                <TextBlock Text="• 密码"
                           FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="20,0,0,3"/>

                <TextBlock Text="• 休息间隔时间"
                           FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="20,0,0,3"/>

                <TextBlock Text="• 休息时长"
                           FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="20,0,0,3"/>

                <TextBlock Text="• 休息模式设置"
                           FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="20,0,0,3"/>

                <TextBlock Text="• 图片文件夹路径"
                           FontSize="13"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="20,0,0,15"/>

                <Border Background="#FFF3CD"
                        Padding="10"
                        CornerRadius="4">
                    <TextBlock Text="程序将退出并恢复默认设置，下次启动时需要重新设置密码。"
                               FontSize="13"
                               TextWrapping="Wrap"
                               Foreground="#856404"/>
                </Border>
            </StackPanel>

            <!-- 按钮 -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1"
                        Content="取消"
                        Click="OnCancelClick"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="80"
                        Height="36"
                        Margin="0,0,10,0"
                        Background="#F5F5F5"
                        Foreground="#333333"/>

                <Button Grid.Column="2"
                        Content="确定重置"
                        Click="OnConfirmClick"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="100"
                        Height="36"
                        Background="#F44336"
                        Foreground="White"/>
            </Grid>
        </Grid>
    </Border>
</Window>
