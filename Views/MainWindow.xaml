<Window x:Class="eyesharp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EyeSharp 护眼助手"
        Width="800"
        Height="700"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        ResizeMode="CanMinimize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="EyeSharp 护眼助手"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="定时提醒休息，保护您的眼睛"
                           FontSize="14"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,5,0,0"/>
            </StackPanel>

            <!-- 主题切换按钮 - 右上角 -->
            <Button Grid.Column="1"
                    Command="{Binding ToggleThemeCommand}"
                    Style="{DynamicResource ThemeToggleButtonStyle}"
                    ToolTip="切换亮色/深色主题"
                    VerticalAlignment="Top"
                    Content="{Binding ThemeButtonIcon}"/>
        </Grid>

        <!-- 主内容区域 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

            <!-- 状态显示区域 -->
            <Border Grid.Row="0"
                    Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20"
                    Margin="0,0,0,15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 状态文本 -->
                    <TextBlock Grid.Row="0"
                               Text="{Binding StatusText}"
                               FontSize="16"
                               FontWeight="Medium"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,10"/>

                    <!-- 倒计时显示 -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="距离下次休息："
                                       FontSize="14"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding CountdownText}"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       Margin="10,0,0,0"/>
                        </StackPanel>

                        <!-- 暂停/恢复按钮 -->
                        <Button Grid.Column="2"
                                Content="{Binding PauseResumeButtonText}"
                                Command="{Binding PauseResumeCommand}"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Width="100"
                                Height="36"/>
                    </Grid>

                    <!-- 进度条 -->
                    <ProgressBar Grid.Row="2"
                                 Value="{Binding CountdownProgress}"
                                 Maximum="100"
                                 Height="4"
                                 Margin="0,12,0,0"
                                 Foreground="{DynamicResource PrimaryBrush}"
                                 Background="{DynamicResource BorderBrush}"
                                 BorderThickness="0"/>
                </Grid>
            </Border>

            <!-- 设置卡片区域 -->
            <Grid Grid.Row="1" Margin="0,0,0,15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 卡片1：时间设置 -->
                <Border Grid.Row="0"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 卡片标题 -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="🕐" FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="时间设置"
                                       FontSize="16"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>

                        <!-- 休息间隔设置 -->
                        <Grid Grid.Row="1" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="休息间隔："
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>

                            <Slider Grid.Column="1"
                                    Minimum="1"
                                    Maximum="120"
                                    Value="{Binding RestIntervalMinutes}"
                                    VerticalAlignment="Center"
                                    IsEnabled="{Binding IsSettingsEnabled}"/>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBox Text="{Binding RestIntervalMinutes, UpdateSourceTrigger=PropertyChanged}"
                                         Width="50"
                                         VerticalAlignment="Center"
                                         Style="{DynamicResource TextBoxStyle}"
                                         IsEnabled="{Binding IsSettingsEnabled}"/>
                                <TextBlock Text=" 分钟"
                                           VerticalAlignment="Center"
                                           Margin="5,0,0,0"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Grid>

                        <!-- 休息时长设置 -->
                        <Grid Grid.Row="2" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="休息时长："
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>

                            <Slider Grid.Column="1"
                                    Minimum="5"
                                    Maximum="300"
                                    Value="{Binding RestDurationSeconds}"
                                    VerticalAlignment="Center"
                                    IsEnabled="{Binding IsSettingsEnabled}"/>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBox Text="{Binding RestDurationSeconds, UpdateSourceTrigger=PropertyChanged}"
                                         Width="50"
                                         VerticalAlignment="Center"
                                         Style="{DynamicResource TextBoxStyle}"
                                         IsEnabled="{Binding IsSettingsEnabled}"/>
                                <TextBlock Text=" 秒"
                                           VerticalAlignment="Center"
                                           Margin="5,0,0,0"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Grid>

                        <!-- 休息前预提醒 -->
                        <Grid Grid.Row="3">
                            <CheckBox Content="休息前30秒和10秒显示预提醒"
                                      IsChecked="{Binding IsPreReminderEnabled}"
                                      FontSize="14"
                                      Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- 卡片2：休息模式 -->
                <Border Grid.Row="1"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 卡片标题 -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="🖼️" FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="休息模式"
                                       FontSize="16"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>

                        <!-- 强制模式 -->
                        <Grid Grid.Row="1" Margin="0,0,0,12">
                            <CheckBox Content="强制休息模式（需输入密码才能提前结束休息）"
                                      IsChecked="{Binding IsForcedMode}"
                                      FontSize="14"
                                      Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Grid>

                        <!-- 休息窗口模式 -->
                        <Grid Grid.Row="2" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="休息窗口："
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <RadioButton Content="黑屏"
                                             GroupName="RestWindowMode"
                                             IsChecked="{Binding IsBlackMode}"
                                             Margin="0,0,20,0"
                                             FontSize="14"/>
                                <RadioButton Content="图片轮播"
                                             GroupName="RestWindowMode"
                                             IsChecked="{Binding IsImageMode}"
                                             FontSize="14"/>
                            </StackPanel>
                        </Grid>

                        <!-- 自定义图片路径 -->
                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="图片文件夹："
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>

                            <TextBox Grid.Column="1"
                                     Text="{Binding CustomImagePath}"
                                     VerticalAlignment="Center"
                                     IsReadOnly="True"
                                     Style="{DynamicResource TextBoxStyle}"/>

                            <Button Grid.Column="2"
                                    Content="浏览..."
                                    Command="{Binding BrowseImageCommand}"
                                    Width="80"
                                    Height="32"
                                    Margin="10,0,0,0"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- 卡片3：其他设置 -->
                <Border Grid.Row="2"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 卡片标题 -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="⚙️" FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="其他设置"
                                       FontSize="16"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>

                        <!-- 开机自启动 -->
                        <Grid Grid.Row="1" Margin="0,0,0,12">
                            <CheckBox Content="开机自启动"
                                      IsChecked="{Binding AutoStart}"
                                      FontSize="14"
                                      Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Grid>

                        <!-- 日志级别 -->
                        <Grid Grid.Row="2" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="日志级别："
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>

                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding LogLevelOptions}"
                                      SelectedItem="{Binding SelectedLogLevel}"
                                      VerticalAlignment="Center"
                                      Width="120"
                                      HorizontalAlignment="Left"/>
                        </Grid>

                        <!-- 锁屏处理方式 -->
                        <Grid Grid.Row="3" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="锁屏处理："
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <RadioButton Content="正常显示"
                                             GroupName="LockScreenBehavior"
                                             IsChecked="{Binding IsLockScreenBehaviorNormal}"
                                             Margin="0,0,15,0"
                                             FontSize="14"
                                             ToolTip="锁屏时正常显示休息窗口（解锁后可见）"/>
                                <RadioButton Content="暂停倒计时"
                                             GroupName="LockScreenBehavior"
                                             IsChecked="{Binding IsLockScreenBehaviorPause}"
                                             Margin="0,0,15,0"
                                             FontSize="14"
                                             ToolTip="锁屏时暂停倒计时，解锁后继续"/>
                                <RadioButton Content="跳过休息"
                                             GroupName="LockScreenBehavior"
                                             IsChecked="{Binding IsLockScreenBehaviorSkip}"
                                             FontSize="14"
                                             ToolTip="锁屏时跳过本次休息提醒"/>
                            </StackPanel>
                        </Grid>

                        <!-- 保存按钮 -->
                        <Button Grid.Row="4"
                                Content="保存所有设置"
                                Command="{Binding ApplySettingsCommand}"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                HorizontalAlignment="Right"
                                Width="120"
                                Height="40"
                                FontSize="14"
                                FontWeight="Bold"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- 操作按钮区域 -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <!-- 数据查看组 -->
                    <Button Command="{Binding ViewStatisticsCommand}"
                            Style="{DynamicResource IconButtonStyle}"
                            ToolTip="查看护眼数据统计">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontSize="14"/>
                            <TextBlock Text="统计" FontSize="14" Margin="5,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- 分隔线 -->
                    <Border Style="{DynamicResource ButtonDividerStyle}"/>

                    <!-- 安全设置组 -->
                    <Button Command="{Binding ChangePasswordCommand}"
                            Style="{DynamicResource IconButtonStyle}"
                            ToolTip="修改休息窗口密码">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔐" FontSize="14"/>
                            <TextBlock Text="改密" FontSize="14" Margin="5,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ForgotPasswordCommand}"
                            Style="{DynamicResource WarningIconButtonStyle}"
                            ToolTip="重置密码（将清除所有配置）">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠️" FontSize="14"/>
                            <TextBlock Text="重置" FontSize="14" Margin="5,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <!-- 分隔线 -->
                    <Border Style="{DynamicResource ButtonDividerStyle}"/>

                    <!-- 系统操作组：隐藏 + 退出 -->
                    <Button Command="{Binding HideToTrayCommand}"
                            Style="{DynamicResource IconButtonStyle}"
                            ToolTip="隐藏到系统托盘">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🪟" FontSize="14"/>
                            <TextBlock Text="隐藏" FontSize="14" Margin="5,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ExitCommand}"
                            Style="{DynamicResource DangerIconButtonStyle}"
                            ToolTip="退出程序">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚪" FontSize="14"/>
                            <TextBlock Text="退出" FontSize="14" Margin="5,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
            </Grid>
        </ScrollViewer>

        <!-- 底部信息 -->
        <TextBlock Grid.Row="2"
                   Text="{Binding VersionInfo}"
                   FontSize="12"
                   Foreground="{DynamicResource TextDisabledBrush}"
                   HorizontalAlignment="Center"
                   Margin="0,20,0,0"/>

        <!-- Toast通知层 -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                x:Name="ToastBorder"
                Background="{DynamicResource SuccessBrush}"
                CornerRadius="8"
                Padding="20,12"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,60,0,0"
                Visibility="{Binding ToastVisibility}"
                Opacity="{Binding ToastOpacity}"
                Panel.ZIndex="100">
            <TextBlock x:Name="ToastText"
                       Text="{Binding ToastMessage}"
                       FontSize="14"
                       FontWeight="Medium"
                       Foreground="White"/>
        </Border>
    </Grid>
</Window>
