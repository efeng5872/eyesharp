<Window x:Class="eyesharp.Views.RestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Black"
        WindowState="Normal">

    <Window.Resources>
        <!-- 淡入动画 -->
        <Storyboard x:Key="FadeInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1"
                             Duration="0:0:1"/>
        </Storyboard>
        <!-- 淡出动画 -->
        <Storyboard x:Key="FadeOutAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1" To="0"
                             Duration="0:0:1"/>
        </Storyboard>
    </Window.Resources>

    <Grid>
        <!-- 背景图片/纯黑 -->
        <Grid x:Name="BackgroundGrid">
            <!-- 黑屏模式 -->
            <Grid.Background>
                <SolidColorBrush Color="Black" x:Name="BackgroundBrush"/>
            </Grid.Background>

            <!-- 图片模式 - 双图切换实现淡入淡出 -->
            <Image x:Name="BackgroundImage1"
                   Stretch="UniformToFill"
                   Visibility="Collapsed"
                   Opacity="1"/>
            <Image x:Name="BackgroundImage2"
                   Stretch="UniformToFill"
                   Visibility="Collapsed"
                   Opacity="0"/>
        </Grid>

        <!-- 右下角控制区 -->
        <StackPanel HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="20"
                    Orientation="Horizontal">
            <!-- 强制模式：密码输入 -->
            <StackPanel x:Name="ForcedModePanel"
                        Orientation="Horizontal"
                        Visibility="Collapsed">
                <TextBlock Text="密码:"
                           FontSize="14"
                           Foreground="#808080"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <PasswordBox x:Name="PasswordBox"
                             FontSize="14"
                             Width="100"
                             Height="30"
                             VerticalAlignment="Center"
                             Margin="0,0,10,0"
                             KeyDown="OnPasswordKeyDown"/>
                <!-- 重置按钮（密码错误3次后显示） -->
                <Button x:Name="ResetButton"
                        Content="重置"
                        Click="OnResetClick"
                        Width="80"
                        Height="30"
                        FontSize="14"
                        Background="#F44336"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,0,10,0"
                        Visibility="Collapsed">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#D32F2F"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <!-- 结束锁屏复选框 -->
                <CheckBox x:Name="LockAfterRestCheckBox"
                          VerticalAlignment="Center"
                          Margin="0,0,15,0"
                          Cursor="Hand"
                          Checked="OnLockAfterRestChecked"
                          ToolTipService.InitialShowDelay="1000"
                          ToolTipService.ToolTip="休息结束后自动锁定电脑，保护隐私安全（勾选后不可取消）">
                    <TextBlock Text="结束锁屏"
                               FontSize="14"
                               Foreground="#808080"
                               VerticalAlignment="Center"/>
                </CheckBox>

                <Button Content="提前结束"
                        Click="OnEndRestClick"
                        Width="80"
                        Height="30"
                        FontSize="14"
                        Background="#404040"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Margin="0,0,20,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#606060"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- 非强制模式：跳过休息按钮和锁屏复选框 -->
            <StackPanel x:Name="NonForcedModePanel"
                        Orientation="Horizontal"
                        Visibility="Collapsed"
                        Margin="0,0,20,0">
                <!-- 结束锁屏复选框 -->
                <CheckBox x:Name="LockAfterRestCheckBoxNonForced"
                          VerticalAlignment="Center"
                          Margin="0,0,15,0"
                          Cursor="Hand"
                          Checked="OnLockAfterRestCheckedNonForced"
                          ToolTipService.InitialShowDelay="1000"
                          ToolTipService.ToolTip="休息结束后自动锁定电脑，保护隐私安全（勾选后不可取消）">
                    <TextBlock Text="结束锁屏"
                               FontSize="14"
                               Foreground="#808080"
                               VerticalAlignment="Center"/>
                </CheckBox>

                <Button x:Name="SkipRestButton"
                        Content="跳过休息"
                        Click="OnSkipRestClick"
                        Width="80"
                        Height="30"
                        FontSize="14"
                        Background="#404040"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#606060"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- 倒计时显示 -->
            <TextBlock x:Name="CountdownText"
                       Text="00:20"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="#808080"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
