<Window x:Class="eyesharp.Views.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:eyesharp.Views"
        Title="EyeSharp 数据统计" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        ResizeMode="CanResize"
        MinWidth="600" MinHeight="400">

    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="10" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="2" BlurRadius="5" Opacity="0.2" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="36" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
        </Style>

        <Style x:Key="StatLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Margin" Value="0,5,0,0" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Margin" Value="10,15,10,5" />
        </Style>

        <!-- 刷新按钮样式 -->
        <Style x:Key="RefreshButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <local:IsCompletedConverter x:Key="IsCompletedConverter" />
        <local:IsForcedModeConverter x:Key="IsForcedModeConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="{DynamicResource PrimaryBrush}" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="📊" FontSize="24" Margin="0,0,10,0" />
                    <TextBlock Text="护眼数据统计" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" />
                </StackPanel>

                <Button Grid.Column="1" Content="刷新" Width="80" Height="32"
                        Style="{StaticResource RefreshButtonStyle}"
                        Click="RefreshButton_Click" />
            </Grid>
        </Border>

        <!-- 统计卡片区域 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="300">
            <StackPanel>
                <!-- 今日统计 -->
                <TextBlock Text="今日统计" Style="{StaticResource SectionTitleStyle}" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock x:Name="TodayCountText" Text="0" Style="{StaticResource StatValueStyle}" />
                            <TextBlock Text="休息次数" Style="{StaticResource StatLabelStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock x:Name="TodayDurationText" Text="0分" Style="{StaticResource StatValueStyle}" />
                            <TextBlock Text="总休息时长" Style="{StaticResource StatLabelStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock x:Name="TodayCompletedText" Text="0" Style="{StaticResource StatValueStyle}" />
                            <TextBlock Text="正常完成" Style="{StaticResource StatLabelStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock x:Name="TodaySkippedText" Text="0" Style="{StaticResource StatValueStyle}" />
                            <TextBlock Text="提前结束" Style="{StaticResource StatLabelStyle}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 本周统计 -->
                <TextBlock Text="本周统计" Style="{StaticResource SectionTitleStyle}" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock x:Name="WeekCountText" Text="0" Style="{StaticResource StatValueStyle}" />
                            <TextBlock Text="休息次数" Style="{StaticResource StatLabelStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock x:Name="WeekDurationText" Text="0分" Style="{StaticResource StatValueStyle}" />
                            <TextBlock Text="总休息时长" Style="{StaticResource StatLabelStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock x:Name="WeekCompletedText" Text="0" Style="{StaticResource StatValueStyle}" />
                            <TextBlock Text="正常完成" Style="{StaticResource StatLabelStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock x:Name="WeekSkippedText" Text="0" Style="{StaticResource StatValueStyle}" />
                            <TextBlock Text="提前结束" Style="{StaticResource StatLabelStyle}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 本月统计 -->
                <TextBlock Text="本月统计" Style="{StaticResource SectionTitleStyle}" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock x:Name="MonthCountText" Text="0" Style="{StaticResource StatValueStyle}" />
                            <TextBlock Text="休息次数" Style="{StaticResource StatLabelStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock x:Name="MonthDurationText" Text="0分" Style="{StaticResource StatValueStyle}" />
                            <TextBlock Text="总休息时长" Style="{StaticResource StatLabelStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock x:Name="MonthCompletedText" Text="0" Style="{StaticResource StatValueStyle}" />
                            <TextBlock Text="正常完成" Style="{StaticResource StatLabelStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock x:Name="MonthSkippedText" Text="0" Style="{StaticResource StatValueStyle}" />
                            <TextBlock Text="提前结束" Style="{StaticResource StatLabelStyle}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- 最近记录表格 -->
        <Border Grid.Row="2" Margin="10" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="最近休息记录" FontSize="16" FontWeight="SemiBold"
                          Margin="15,10" Foreground="{DynamicResource TextPrimaryBrush}" />

                <DataGrid Grid.Row="1" x:Name="RecordsDataGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0"
                          HeadersVisibility="Column"
                          RowHeight="35"
                          Background="{DynamicResource CardBackgroundBrush}"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          Margin="10">
                    <DataGrid.Resources>
                        <!-- 表头样式 -->
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Padding" Value="10,5" />
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                            <Setter Property="BorderThickness" Value="0,0,0,1" />
                        </Style>
                        <!-- 单元格样式 -->
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="10,5" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                        <!-- 行样式 -->
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource BorderBrush}" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
                                    <Setter Property="Foreground" Value="White" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="开始时间" Binding="{Binding StartTime, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="160" />
                        <DataGridTextColumn Header="结束时间" Binding="{Binding EndTime, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="160" />
                        <DataGridTextColumn Header="计划时长" Binding="{Binding PlannedDurationSeconds, StringFormat={}{0}秒}" Width="80" />
                        <DataGridTextColumn Header="实际时长" Binding="{Binding DurationSeconds, StringFormat={}{0}秒}" Width="80" />
                        <DataGridTextColumn Header="状态" Width="100" Binding="{Binding IsCompleted, Converter={StaticResource IsCompletedConverter}}" />
                        <DataGridTextColumn Header="模式" Width="80" Binding="{Binding IsForcedMode, Converter={StaticResource IsForcedModeConverter}}" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Window>
